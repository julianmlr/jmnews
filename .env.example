# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
JMNEWS_FILTER_MODEL=claude-haiku-4-5-20251001
JMNEWS_BRIEFING_MODEL=claude-sonnet-4-6

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# Paths (optional, sinnvolle Defaults sind gesetzt)
JMNEWS_DB_PATH=data/jmnews.db
JMNEWS_PROFILE_PATH=jm_profile.md
JMNEWS_BRIEFINGS_DIR=data/briefings

# Behaviour
JMNEWS_LOOKBACK_HOURS=24
JMNEWS_FILTER_BATCH_SIZE=15
JMNEWS_PURGE_DAYS=30
JMNEWS_TIMEZONE=Europe/Berlin
JMNEWS_COLLECT_HOUR=6
JMNEWS_COLLECT_MINUTE=45
JMNEWS_DELIVER_HOUR=7
JMNEWS_DELIVER_MINUTE=0

# Logging
JMNEWS_LOG_LEVEL=INFO
JMNEWS_LOG_DIR=data/logs
